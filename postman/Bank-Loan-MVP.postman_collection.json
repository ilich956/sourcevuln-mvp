{
  "info": {
    "_postman_id": "e7f6410f-7ed4-4b7f-bf35-f03f68eb95c5",
    "name": "Bank Loan MVP API",
    "description": "Ready-to-run collection for bank-loan-mvp. Run requests top-to-bottom. Client flow works out-of-the-box by registering a fresh client. Manager/Admin requests require valid credentials in environment variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('baseUrl')) {",
          "  pm.environment.set('baseUrl', 'http://localhost:8080');",
          "}",
          "if (!pm.environment.get('client_email')) {",
          "  pm.environment.set('client_email', 'client+' + Date.now() + '@example.com');",
          "}",
          "if (!pm.environment.get('client_password')) {",
          "  pm.environment.set('client_password', 'ClientPass123!');",
          "}",
          "if (!pm.environment.get('client_full_name')) {",
          "  pm.environment.set('client_full_name', 'Postman Client');",
          "}",
          "if (!pm.environment.get('target_user_id')) {",
          "  pm.environment.set('target_user_id', '33333333-3333-3333-3333-333333333333');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Health payload is ok', function () {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data.status).to.eql('ok');",
                  "  pm.expect(json.data.db).to.eql('ok');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Auth - Client Flow",
      "item": [
        {
          "name": "POST /api/v1/auth/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.environment.set('client_user_id', json.data.id);",
                  "}",
                  "pm.test('Registered role is client', function () {",
                  "  pm.expect(json.data.role).to.eql('client');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{client_email}}\",\n  \"password\": \"{{client_password}}\",\n  \"full_name\": \"{{client_full_name}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "POST /api/v1/auth/login (client)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "const data = json.data || {};",
                  "pm.environment.set('client_access_token', data.access_token || '');",
                  "pm.environment.set('client_refresh_token', data.refresh_token || '');",
                  "pm.environment.set('access_token', data.access_token || '');",
                  "pm.environment.set('refresh_token', data.refresh_token || '');",
                  "pm.test('Has access token', function () {",
                  "  pm.expect(data.access_token).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{client_email}}\",\n  \"password\": \"{{client_password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "POST /api/v1/auth/refresh",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "const data = json.data || {};",
                  "if (data.access_token) {",
                  "  pm.environment.set('client_access_token', data.access_token);",
                  "  pm.environment.set('access_token', data.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{client_refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh"
              ]
            }
          }
        }
      ]
    },
