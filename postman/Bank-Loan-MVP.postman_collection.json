    {
      "name": "Auth - Manager and Admin",
      "item": [
        {
          "name": "POST /api/v1/auth/login (manager)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = (pm.response.json().data || {});",
                  "  pm.environment.set('manager_access_token', data.access_token || '');",
                  "  pm.environment.set('manager_refresh_token', data.refresh_token || '');",
                  "}",
                  "pm.test('Manager login succeeded (set manager_password correctly if failing)', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
